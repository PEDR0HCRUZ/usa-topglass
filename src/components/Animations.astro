<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  // ─────────────────────────────────────────────
  // HERO — entrance timeline
  // ─────────────────────────────────────────────
  const heroTl = gsap.timeline({ delay: 0.15 })

  heroTl
    .from('[data-gsap="hero-badge"]', {
      y: -18,
      opacity: 0,
      stagger: 0.12,
      duration: 0.55,
      ease: 'power2.out',
    })
    .from(
      '[data-gsap="hero-title"]',
      { y: 40, opacity: 0, duration: 0.75, ease: 'power3.out' },
      '-=0.25'
    )
    .from(
      '[data-gsap="hero-desc"]',
      { y: 25, opacity: 0, duration: 0.6, ease: 'power2.out' },
      '-=0.45'
    )
    .from(
      '[data-gsap="hero-ctas"]',
      { y: 20, opacity: 0, duration: 0.55, ease: 'power2.out' },
      '-=0.35'
    )

  // Hero background — subtle Ken Burns
  gsap.to('section:first-of-type .absolute.inset-0 img', {
    scale: 1.06,
    duration: 12,
    ease: 'none',
    repeat: -1,
    yoyo: true,
  })

  // ─────────────────────────────────────────────
  // NAVBAR — shrink on scroll
  // ─────────────────────────────────────────────
  ScrollTrigger.create({
    start: 'top -60',
    onEnter: () =>
      gsap.to('nav', {
        paddingTop: '0px',
        paddingBottom: '0px',
        duration: 0.35,
        ease: 'power2.out',
      }),
    onLeaveBack: () =>
      gsap.to('nav', {
        duration: 0.35,
        ease: 'power2.out',
      }),
  })

  // ─────────────────────────────────────────────
  // SCROLL REVEALS — section labels + headings
  // ─────────────────────────────────────────────
  gsap.utils.toArray<HTMLElement>('.section-tag').forEach((el) => {
    gsap.from(el, {
      scrollTrigger: { trigger: el, start: 'top 90%' },
      x: -24,
      opacity: 0,
      duration: 0.5,
      ease: 'power2.out',
    })
  })

  gsap.utils.toArray<HTMLElement>('h2').forEach((el) => {
    gsap.from(el, {
      scrollTrigger: { trigger: el, start: 'top 88%' },
      y: 32,
      opacity: 0,
      duration: 0.7,
      ease: 'power2.out',
    })
  })

  // Generic fade-up for paragraphs inside sections
  gsap.utils.toArray<HTMLElement>('section p:not(nav p)').forEach((el) => {
    gsap.from(el, {
      scrollTrigger: { trigger: el, start: 'top 92%' },
      y: 18,
      opacity: 0,
      duration: 0.55,
      ease: 'power1.out',
    })
  })

  // ─────────────────────────────────────────────
  // TRUST BAR — stagger icons
  // ─────────────────────────────────────────────
  gsap.from('[data-section="trust"] > div > div', {
    scrollTrigger: { trigger: '[data-section="trust"]', start: 'top 85%' },
    y: 20,
    opacity: 0,
    stagger: 0.1,
    duration: 0.5,
    ease: 'power2.out',
  })

  // ─────────────────────────────────────────────
  // SERVICES — card stagger
  // ─────────────────────────────────────────────
  const serviceCards = gsap.utils.toArray<HTMLElement>('[data-section="services"] .group')
  if (serviceCards.length) {
    gsap.from(serviceCards, {
      scrollTrigger: { trigger: serviceCards[0], start: 'top 82%' },
      y: 50,
      opacity: 0,
      stagger: 0.13,
      duration: 0.65,
      ease: 'power2.out',
    })
  }

  // ─────────────────────────────────────────────
  // WHY US — left/right slide
  // ─────────────────────────────────────────────
  const whyLeft = document.querySelector('[data-section="whyus"] .whyus-left')
  const whyRight = document.querySelector('[data-section="whyus"] .whyus-right')

  if (whyLeft) {
    gsap.from(whyLeft, {
      scrollTrigger: { trigger: whyLeft, start: 'top 82%' },
      x: -50,
      opacity: 0,
      duration: 0.75,
      ease: 'power2.out',
    })
  }
  if (whyRight) {
    gsap.from(whyRight, {
      scrollTrigger: { trigger: whyRight, start: 'top 82%' },
      x: 50,
      opacity: 0,
      duration: 0.75,
      ease: 'power2.out',
    })
  }

  // ─────────────────────────────────────────────
  // GALLERY — stagger photos
  // ─────────────────────────────────────────────
  const galleryPhotos = gsap.utils.toArray<HTMLElement>('[data-section="gallery"] .group')
  if (galleryPhotos.length) {
    gsap.from(galleryPhotos, {
      scrollTrigger: { trigger: galleryPhotos[0], start: 'top 85%' },
      y: 40,
      opacity: 0,
      scale: 0.97,
      stagger: 0.1,
      duration: 0.6,
      ease: 'power2.out',
    })
  }

  // ─────────────────────────────────────────────
  // CONTACT FORM — slide up
  // ─────────────────────────────────────────────
  gsap.from('[data-section="contact"] form', {
    scrollTrigger: { trigger: '[data-section="contact"] form', start: 'top 85%' },
    y: 45,
    opacity: 0,
    duration: 0.75,
    ease: 'power2.out',
  })

  // ─────────────────────────────────────────────
  // MICRO-INTERACTIONS — buttons magnetic hover
  // ─────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.btn-primary, .btn-white, .btn-secondary').forEach((btn) => {
    btn.addEventListener('mouseenter', () => {
      gsap.to(btn, { scale: 1.04, duration: 0.2, ease: 'power1.out' })
    })
    btn.addEventListener('mouseleave', () => {
      gsap.to(btn, { scale: 1, duration: 0.25, ease: 'power1.out' })
    })
    btn.addEventListener('mousedown', () => {
      gsap.to(btn, { scale: 0.97, duration: 0.1 })
    })
    btn.addEventListener('mouseup', () => {
      gsap.to(btn, { scale: 1.04, duration: 0.1 })
    })
  })

  // ─────────────────────────────────────────────
  // MICRO-INTERACTION — phone CTA pulse
  // ─────────────────────────────────────────────
  const phoneCta = document.querySelector<HTMLElement>('a[href^="tel"]')
  if (phoneCta) {
    gsap.to(phoneCta, {
      boxShadow: '0 0 0 6px rgba(27,79,138,0.18)',
      repeat: -1,
      yoyo: true,
      duration: 1.4,
      ease: 'power1.inOut',
      delay: 3,
    })
  }
</script>
